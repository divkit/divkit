      "variables": [
        {
          "name": "active_item",
          "type": "integer",
          "value": 1
        }
      ],
      "states": [
        {
          "state_id": 0,
          "div": {
            "type": "container",
            "orientation": "vertical",
            "items": [
              {
                "type": "section_header",
                "text": "scroll_mode = default, scroll_alignment = start"
              },
              {
