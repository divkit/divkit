          {
            "type": "text_block",
            "text": "Item 5",
            "background": [
              {
                "type": "solid",
                "color": "@{active_item == 5 ? '#a8d4a0' : '#d8d8d8'}"
              }
            ]
          }
        ]
      }
    },
    "card": {
