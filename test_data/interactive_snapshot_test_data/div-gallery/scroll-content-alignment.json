{
  "description": "Gallery scroll_content_alignment: start, center, end with default and paging scroll modes",
  "platforms": [
    "ios"
  ],
  "div_data": {
    "templates": {
      "section_header": {
        "type": "text",
        "font_size": 16,
        "font_weight": "bold",
        "text_color": "#888",
        "paddings": {
          "left": 10,
          "right": 10,
          "top": 14,
          "bottom": 2
        }
      },
      "text_block": {
        "type": "text",
        "width": {
          "type": "fixed",
          "value": 150
        },
        "height": {
          "type": "fixed",
          "value": 80
        },
        "border": {
          "corner_radius": 6
        },
        "font_size": 20,
        "text_alignment_vertical": "center",
        "text_alignment_horizontal": "center",
        "background": [
          {
            "type": "solid",
            "color": "@{active_item == item_index ? '#a8d4a0' : '#d8d8d8'}"
          }
        ],
        "$item_index": "index_var_name"
      },
      "demo_gallery": {
        "type": "gallery",
        "default_item": 1,
        "items": [
          {
            "type": "text_block",
            "text": "Item 0",
            "background": [
              {
                "type": "solid",
                "color": "@{active_item == 0 ? '#a8d4a0' : '#d8d8d8'}"
              }
            ]
          },
          {
            "type": "text_block",
            "text": "Item 1",
            "background": [
              {
                "type": "solid",
                "color": "@{active_item == 1 ? '#a8d4a0' : '#d8d8d8'}"
              }
            ]
          },
          {
            "type": "text_block",
            "text": "Item 2",
            "background": [
              {
                "type": "solid",
                "color": "@{active_item == 2 ? '#a8d4a0' : '#d8d8d8'}"
              }
            ]
          },
          {
            "type": "text_block",
            "text": "Item 3",
            "background": [
              {
                "type": "solid",
                "color": "@{active_item == 3 ? '#a8d4a0' : '#d8d8d8'}"
              }
