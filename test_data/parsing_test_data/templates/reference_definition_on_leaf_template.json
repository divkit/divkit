{
  "description": "The reference definition lives inside the leaf template's definition itself — not on any usage site. Verifies the card instance's reference value still cascades through two levels of template-body content down to the leaf template's own reference.",
  "templates": {
    "root_container": {
      "type": "container",
      "items": [
        {
          "type": "nested_container"
        }
      ]
    },
    "nested_container": {
      "type": "container",
      "items": [
        {
          "type": "title_text"
        }
      ]
    },
    "title_text": {
      "$text": "titleTextRef",
      "type": "text"
    }
  },
  "card": {
    "log_id": "test",
    "states": [
      {
        "state_id": 0,
        "div": {
          "titleTextRef": "Title Text",
          "type": "root_container"
        }
      }
    ]
  },
  "expected": {
    "card": {
      "log_id": "test",
      "states": [
        {
          "state_id": 0,
          "div": {
            "type": "container",
            "items": [
              {
                "type": "container",
                "items": [
                  {
                    "text": "Title Text",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  }
}
