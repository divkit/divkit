{
  "description": "Link (titleTextRef) exist in the middle of template resolution chain (nested_container)",
  "templates": {
    "root_container": {
      "type": "container",
      "items": [
        {
          "type": "nested_container"
        }
      ]
    },
    "nested_container": {
      "type": "container",
      "items": [
        {
          "type": "title_text",
          "$text": "titleTextRef"
        }
      ]
    },
    "title_text": {
      "type": "text"
    }
  },
  "card": {
    "log_id": "test",
    "states": [
      {
        "state_id": 0,
        "div": {
          "titleTextRef": "Title Text",
          "type": "root_container"
        }
      }
    ]
  },
  "expected": {
    "card": {
      "log_id": "test",
      "states": [
        {
          "state_id": 0,
          "div": {
            "type": "container",
            "items": [
              {
                "type": "container",
                "items": [
                  {
                    "text": "Title Text",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  }
}