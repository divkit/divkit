{
  "description": "Reference should work inside nested object.",
  "platforms": [
    "web"
  ],
  "templates": {
    "page": {
      "type": "container",
      "width": {
        "type": "fixed",
        "value": 100
      },
      "height": {
        "type": "fixed",
        "value": 100
      },
      "background": [
        {
          "type": "solid",
          "$color": "background_color"
        }
      ]
    },
    "inline_page": {
      "type": "page",
      "background_color": "#D33682"
    }
  },
  "card": {
    "log_id": "a",
    "states": [
      {
        "state_id": 0,
        "div": {
          "type": "inline_page"
        }
      }
    ]
  },
  "expected": {
    "card": {
      "log_id": "test",
      "states": [
        {
          "state_id": 0,
          "div": {
            "type": "container",
            "width": {
              "type": "fixed",
              "value": 100
            },
            "height": {
              "type": "fixed",
              "value": 100
            },
            "background": [
              {
                "type": "solid",
                "color": "#D33682"
              }
            ]
          }
        }
      ]
    }
  }
}
