{
  "description": "A single template definition reuses the same reference source name ('content') at two depths: a top-level $text and a nested $log_id inside actions[]. Verifies both sites receive the same value from the usage's reference value.",
  "templates": {
    "action_text": {
      "type": "text",
      "$text": "content",
      "actions": [
        {
          "$log_id": "content",
          "url": "action://do"
        }
      ]
    }
  },
  "card": {
    "log_id": "test",
    "states": [
      {
        "state_id": 0,
        "div": {
          "type": "action_text",
          "content": "button"
        }
      }
    ]
  },
  "expected": {
    "card": {
      "log_id": "test",
      "states": [
        {
          "state_id": 0,
          "div": {
            "type": "text",
            "text": "button",
            "actions": [
              {
                "log_id": "button",
                "url": "action://do"
              }
            ]
          }
        }
      ]
    }
  }
}
