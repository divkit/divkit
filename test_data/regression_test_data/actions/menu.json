                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "button",
              "text": "Button with action and menu",
              "actions": [
                {
                  "log_id": "button2",
                  "menu_items": [
                    {
                      "text": "Menu Item 3",
                      "action": {
                        "log_id": "menu_item_3",
                        "url": "div-action://set_variable?name=last_action&value=Menu Item 3 selected"
