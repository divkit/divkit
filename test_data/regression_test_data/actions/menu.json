              "actions": [
                {
                  "log_id": "button1",
                  "menu_items": [
                    {
                      "text": "Menu Item 1",
                      "action": {
                        "log_id": "menu_item_1",
                        "url": "div-action://set_variable?name=last_action&value=Menu Item 1 selected"
                      }
                    },
                    {
                      "text": "Menu Item 2",
                      "action": {
                        "log_id": "menu_item_2",
                        "url": "div-action://set_variable?name=last_action&value=Menu Item 2 selected"
                      }
                    },
                    {
                      "log_id": "disabled_menu_item",
