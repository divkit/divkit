{
  "templates": {
    "text_block": {
      "type": "text",
      "width": {
        "type": "match_parent"
      },
      "height": {
        "type": "wrap_content"
      },
      "paddings": {
        "left": 24,
        "top": 16,
        "right": 16,
        "bottom": 16
      },
      "margins": {
        "left": 24,
        "right": 24,
        "top": 4,
        "bottom": 4
      },
      "border": {
        "corner_radius": 8
      },
      "background": [
        {
          "type": "solid",
          "color": "#0E000000"
        }
      ],
      "font_size": 14,
      "font_weight": "medium",
      "text_alignment_vertical": "center",
      "text_alignment_horizontal": "center",
      "text_color": "#000000"
    },
    "test_input": {
      "type": "input",
      "width": {
        "type": "match_parent"
      },
      "height": {
        "type": "wrap_content"
      },
      "paddings": {
        "left": 16,
        "top": 16,
        "right": 16,
        "bottom": 16
      },
      "margins": {
        "left": 16,
        "top": 16,
        "right": 16,
        "bottom": 16
      },
      "border": {
        "corner_radius": 8,
