{
  "description": "Text with custom ellipsis whose ranges and images are generated by range_builder and image_builder.",
  "platforms": [
    "ios"
  ],
  "card": {
    "log_id": "snapshot_test_card",
    "states": [
      {
        "state_id": 0,
        "div": {
          "type": "text",
          "variables": [
            {
              "name": "range_source",
              "type": "array",
              "value": [
                { "from": 2, "to": 6, "color": "#FF0000" },
                { "from": 7, "to": 11, "color": "#0000FF" }
              ]
            },
            {
              "name": "image_source",
              "type": "array",
              "value": [
                { "pos": 0, "kind": "star" }
              ]
            }
          ],
          "text": "This is very very very very very very very very very very very very long text with a custom ellipsis",
          "font_size": 18,
          "max_lines": 2,
          "width": {
            "type": "fixed",
            "value": 300
          },
          "ellipsis": {
            "text": "  more",
            "range_builder": {
              "data": "@{range_source}",
              "data_element_name": "it",
              "prototypes": [
                {
                  "range": {
                    "start": "@{getIntegerFromDict(it, 'from')}",
                    "end": "@{getIntegerFromDict(it, 'to')}",
                    "font_weight": "bold",
                    "text_color": "@{getStringFromDict(it, 'color')}"
                  }
                }
              ]
            },
            "image_builder": {
              "data": "@{image_source}",
              "data_element_name": "it",
              "prototypes": [
                {
                  "selector": "@{getStringFromDict(it, 'kind') == 'star'}",
                  "image": {
                    "start": "@{getIntegerFromDict(it, 'pos')}",
                    "url": "https://yastatic.net/s3/home/divkit/star.png",
                    "width": { "type": "fixed", "value": 18 },
                    "height": { "type": "fixed", "value": 18 }
                  }
                }
              ]
            }
          }
        }
      }
    ]
  }
}
